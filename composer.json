{
    "name": "laraveldaily/filateams",
    "description": "Team management plugin for Filament, compatible with Laravel starter kit teams.",
    "keywords": ["laravel", "filament", "teams", "multi-tenancy"],
    "homepage": "https://github.com/laraveldaily/filateams",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Laravel Daily",
            "homepage": "https://laraveldaily.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.28|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^4.4",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "LaravelDaily\\FilaTeams\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "LaravelDaily\\FilaTeams\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelDaily\\FilaTeams\\FilaTeamsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
